# ============================================================
#  RetailTrove — Environment Variable Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# PostgreSQL Database
# Required for all database operations.
# For Neon: copy the connection string from your Neon dashboard.
# For local Postgres: use postgresql://user:password@localhost:5432/dbname
# ------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Individual Postgres connection parameters (used alongside DATABASE_URL
# by some tooling — drizzle-kit, pg CLI, etc.)
PGHOST=HOST
PGPORT=5432
PGDATABASE=DBNAME
PGUSER=USER
PGPASSWORD=PASSWORD

# ------------------------------------------------------------
# Application
# NODE_ENV is set automatically by npm scripts (dev / build / start).
# Only set manually if you need to override it.
# ------------------------------------------------------------
# NODE_ENV=development

# ------------------------------------------------------------
# Planned — Phase 1: Authentication (Supabase)
# Uncomment and populate when Supabase Auth is integrated.
# ------------------------------------------------------------
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------
# Planned — Phase 2: Lemon Squeezy (Card Payments)
# Uncomment and populate when Lemon Squeezy is integrated.
# ------------------------------------------------------------
# LEMONSQUEEZY_API_KEY=your-api-key
# LEMONSQUEEZY_STORE_ID=your-store-id
# LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# ------------------------------------------------------------
# Planned — Phase 2: M-Pesa (Mobile Money — Safaricom Daraja)
# Uncomment and populate when M-Pesa is integrated.
# ------------------------------------------------------------
# MPESA_CONSUMER_KEY=your-consumer-key
# MPESA_CONSUMER_SECRET=your-consumer-secret
# MPESA_SHORTCODE=your-shortcode
# MPESA_PASSKEY=your-passkey
# MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
# MPESA_ENVIRONMENT=sandbox   # sandbox | production
